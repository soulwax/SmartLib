    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "concurrently": "^9.1.2",
    "dotenv": "^17.3.1",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5",
    "tailwindcss": "^3.4.17",
    "typescript": "5.7.3",
    "wait-on": "^8.0.3"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.7",
      "@types/react-dom": "19.2.3"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "electron",
      "sharp"
    ]
  }
}
