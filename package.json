{
  "name": "my-project",
  "version": "0.2.10",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "next dev --turbo",
    "prebuild": "node -e \"require('node:fs').copyFileSync('CHANGELOG.md', 'public/CHANGELOG.md')\"",
    "build": "next build",
    "start": "next start",
    "lint": "tsc --noEmit",
    "check": "pnpm lint && pnpm build",
    "db:generate": "drizzle-kit generate",
    "db:migrate:reconcile": "node scripts/reconcile-legacy-migrations.mjs",
    "db:migrate": "pnpm db:migrate:reconcile && drizzle-kit migrate",
    "db:backup": "node scripts/db-backup-restore.mjs backup",
    "db:backup:drill": "node scripts/db-backup-restore.mjs drill",
    "db:backup:verify": "node scripts/db-backup-restore.mjs verify",
    "db:restore": "node scripts/db-backup-restore.mjs restore",
    "verify:role-boundaries": "node scripts/verify-role-boundaries.mjs",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "clean": "node scripts/clean.mjs",
    "electron:compile": "tsc --project tsconfig.electron.json",
    "electron:prebuild": "pnpm clean && cross-env BUILD_TARGET=electron next build && pnpm electron:compile",
    "electron:dev": "concurrently --kill-others-on-fail \"pnpm dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "pnpm electron:prebuild && electron-builder",
    "electron:build:mac": "pnpm electron:prebuild && electron-builder --mac",
    "electron:build:win": "pnpm electron:prebuild && electron-builder --win",
    "electron:build:linux": "pnpm electron:prebuild && electron-builder --linux"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@neondatabase/serverless": "^1.0.2",
    "@radix-ui/react-accordion": "1.2.2",
    "@radix-ui/react-alert-dialog": "1.1.4",
    "@radix-ui/react-aspect-ratio": "1.1.1",
    "@radix-ui/react-avatar": "1.1.2",
    "@radix-ui/react-checkbox": "1.1.3",
    "@radix-ui/react-collapsible": "1.1.2",
    "@radix-ui/react-context-menu": "2.2.4",
    "@radix-ui/react-dialog": "1.1.4",
    "@radix-ui/react-dropdown-menu": "2.1.4",
    "@radix-ui/react-hover-card": "1.1.4",
    "@radix-ui/react-label": "2.1.1",
    "@radix-ui/react-menubar": "1.1.4",
    "@radix-ui/react-navigation-menu": "1.2.3",
    "@radix-ui/react-popover": "1.1.4",
    "@radix-ui/react-progress": "1.1.1",
    "@radix-ui/react-radio-group": "1.2.2",
    "@radix-ui/react-scroll-area": "1.2.2",
    "@radix-ui/react-select": "2.1.4",
    "@radix-ui/react-separator": "1.1.1",
    "@radix-ui/react-slider": "1.2.2",
    "@radix-ui/react-slot": "1.1.1",
    "@radix-ui/react-switch": "1.1.2",
    "@radix-ui/react-tabs": "1.1.2",
    "@radix-ui/react-toast": "1.2.4",
    "@radix-ui/react-toggle": "1.1.1",
    "@radix-ui/react-toggle-group": "1.1.1",
    "@radix-ui/react-tooltip": "1.1.6",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "embla-carousel-react": "8.5.1",
    "input-otp": "1.4.1",
    "lucide-react": "^0.544.0",
    "next": "^16.1.6",
    "next-auth": "^4.24.13",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.54.1",
    "react-resizable-panels": "^2.1.7",
    "react-window": "^1.8.11",
    "recharts": "2.15.0",
    "sonner": "^1.7.1",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "ws": "^8.19.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.13",
    "@types/node": "^22",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "concurrently": "^9.1.2",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5",
    "rimraf": "^6.1.3",
    "tailwindcss": "^3.4.17",
    "typescript": "5.7.3",
    "wait-on": "^8.0.3"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.7",
      "@types/react-dom": "19.2.3"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "electron",
      "sharp"
    ]
  },
  "packageManager": "pnpm@10.30.3"
}
