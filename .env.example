# Neon pooled connection string (used by runtime queries)
DATABASE_URL=

# Neon direct/unpooled connection string (reserved for migration tooling)
DATABASE_URL_UNPOOLED=

# Secret used to sign auth session tokens (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=

# Public base URL used by NextAuth callback handling
# Example: https://lib.bluesix.dev
NEXTAUTH_URL=

# If these are left empty, the app runs in temporary mock mode using LIBRARY.md.
# If these are set and the database is empty, resources from LIBRARY.md are auto-seeded once.
GITHUB_CLIENT_ID=your_client_id_here
GITHUB_CLIENT_SECRET=your_client_secret_here
# In GitHub OAuth app settings, set callback URL to:
# https://your-domain/api/auth/callback/github

# Credentials synced into the database on startup; this user is enforced as FirstAdmin
SUPERADMIN_USERNAME=
SUPERADMIN_PASSWORD=
