# Neon pooled connection string (used by runtime queries)
DATABASE_URL=

# Neon direct/unpooled connection string (reserved for migration tooling)
# On Vercel deploys, if this is set, migrations run automatically before the app build.
DATABASE_URL_UNPOOLED=

# Optional Vercel escape hatch. Set to true to skip deploy-time migrations.
VERCEL_SKIP_DB_MIGRATE=

# Secret used to sign auth session tokens (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=

# Public base URL used by NextAuth callback handling
# Must be https:// in production
# Example: https://lib.bluesix.dev
NEXTAUTH_URL=

# Session/token rotation settings (seconds)
# AUTH_SESSION_MAX_AGE_SECONDS default: 604800 (7 days), min: 900, max: 2592000
# AUTH_SESSION_UPDATE_AGE_SECONDS default: 43200 (12 hours), min: 300
AUTH_SESSION_MAX_AGE_SECONDS=604800
AUTH_SESSION_UPDATE_AGE_SECONDS=43200

# If these are left empty, the app runs in temporary mock mode using LIBRARY.md.
# If these are set and the database is empty, resources from LIBRARY.md are auto-seeded once.
GITHUB_CLIENT_ID=your_client_id_here
GITHUB_CLIENT_SECRET=your_client_secret_here
# In GitHub OAuth app settings, set callback URL to:
# https://your-domain/api/auth/callback/github

# Optional email verification delivery via Resend.
# If unset, verification links are logged server-side for development/testing.
RESEND_API_KEY=
EMAIL_FROM=

# Optional override for verification links in emails.
# Falls back to NEXTAUTH_URL, then VERCEL_URL, then http://localhost:3000
EMAIL_VERIFICATION_BASE_URL=
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=Lib Bluesix <noreply@mail.bluesix.dev>
EMAIL_VERIFICATION_BASE_URL=https://lib.bluesix.dev

# Credentials synced into the database on startup; this user is enforced as FirstAdmin
SUPERADMIN_USERNAME=
SUPERADMIN_PASSWORD=

# AI features require a Perplexity API key; sign up at https://www.perplexity.ai/ and generate a key at https://www.perplexity.ai/account/api
PERPLEXITY_API_KEY=

# Optional Redis for distributed rate limiting.
# If unset/unreachable, the app falls back to per-instance in-memory limits.
REDIS_URL=
REDIS_TLS=
